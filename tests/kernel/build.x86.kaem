#
# Build hs with the just-bootstrapped native 32-bit x86 stage0 toolchain.
# Run by the full kaem under --strict. Uses the canonical x86 link flags
# (32-bit: no --64; base 0x8048000; ELF-x86), verified to produce a working hs.

echo ==> M2-Planet: compiling hs.c
./x86/artifact/M2 --architecture x86 \
	-f ./M2libc/sys/types.h \
	-f ./M2libc/stddef.h \
	-f ./M2libc/x86/linux/fcntl.c \
	-f ./M2libc/fcntl.c \
	-f ./M2libc/sys/utsname.h \
	-f ./M2libc/x86/linux/unistd.c \
	-f ./M2libc/x86/linux/sys/stat.c \
	-f ./M2libc/ctype.c \
	-f ./M2libc/stdlib.c \
	-f ./M2libc/stdarg.h \
	-f ./M2libc/stdio.h \
	-f ./M2libc/stdio.c \
	-f ./M2libc/string.c \
	-f ./M2libc/bootstrappable.c \
	-f ./hs.c \
	--debug \
	-o ./hs.M1

echo ==> blood-elf: generating debug stubs
./x86/artifact/blood-elf-0 --little-endian -f ./hs.M1 -o ./hs-footer.M1

echo ==> M1: assembling
./x86/bin/M1 --architecture x86 --little-endian \
	-f ./M2libc/x86/x86_defs.M1 \
	-f ./M2libc/x86/libc-full.M1 \
	-f ./hs.M1 \
	-f ./hs-footer.M1 \
	-o ./hs.hex2

echo ==> hex2: linking
./x86/bin/hex2 --architecture x86 --little-endian --base-address 0x8048000 \
	-f ./M2libc/x86/ELF-x86-debug.hex2 \
	-f ./hs.hex2 \
	-o ./hs

echo ==> Built hs
