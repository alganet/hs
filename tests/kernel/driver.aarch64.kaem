#
# In-kernel master driver (run by kaem-optional-seed, cwd = /).
# Bootstraps a native aarch64 stage0 toolchain from seeds, then builds and
# tests hs. The "mini" chain alone yields M2-Planet/blood-elf/M1/hex2/kaem;
# the heavier full/extra rebuild is intentionally skipped.

./bootstrap-seeds/POSIX/AArch64/kaem-optional-seed ./AArch64/mescc-tools-seed-kaem.kaem
./AArch64/artifact/kaem-0 ./AArch64/mescc-tools-mini-kaem.kaem
./AArch64/bin/kaem --verbose --strict --file ./build.kaem
./AArch64/bin/kaem --verbose --file ./probe.kaem
